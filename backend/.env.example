# Backend environment variables
# Copy this file to .env and adjust values for local development.
# Never commit .env to version control.

PORT=3001
# Local: mongodb://localhost:27017/support_tickets
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/support_tickets
CORS_ORIGIN=http://localhost:5173
